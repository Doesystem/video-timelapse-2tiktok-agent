{
    "name": "video-timelapse-2tiktok-agent",
    "version": "0.0.4",
    "description": "Video Timelapse to TikTok Agent",
    "runtime": "chrome",
    "main": "dist/index.js",
    "public": true,
    "version_public": true,
    "pull_public": true,
    "input": {
        "type": "object",
        "hints": [
            "image_url",
            "product",
            "description",
            "category"
        ]
    },
    "output": {
        "type": "object",
        "hints": [
            "video_url",
            "status",
            "product",
            "category"
        ]
    },
    "keywords": [
        "video",
        "timelapse",
        "tiktok",
        "chrome"
    ],
    "capabilities": {
        "chrome": {
            "required": true,
            "features": [
                "extension",
                "tabs"
            ]
        }
    }
}